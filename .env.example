# ─────────────────────────────────────────────────────────────
# 9th Ward Production & Promotions — Environment Variables
# Copy this file to `.env.local` for local dev, and set the same
# variables in Railway's "Variables" tab for production.
# Only NEXT_PUBLIC_* variables are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# ── Airtable (REQUIRED for content + form intake) ──
# Personal Access Token. Server-side ONLY. Never prefix with NEXT_PUBLIC_.
# Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_PAT=
# Base ID, starts with "app..."
AIRTABLE_BASE_ID=

# ── On-demand revalidation (REQUIRED) ──
# Secret used to protect POST /api/revalidate. Use a long random string.
REVALIDATE_SECRET=

# ── Public site URL (REQUIRED) ──
# Full deployed URL used for canonical links, sitemap, and OG tags.
# e.g. https://9thward.up.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email notifications via Resend (OPTIONAL) ──
# If unset, forms still write to Airtable and succeed — email is skipped.
RESEND_API_KEY=
# Where form-submission alerts are sent.
NOTIFICATION_EMAIL=
# The "from" address for notifications (must be a verified Resend domain).
# Defaults to onboarding@resend.dev if unset (Resend test sender).
RESEND_FROM_EMAIL=

# ── Analytics (OPTIONAL) ──
# If set, mounts the Plausible analytics script. Value = your domain.
NEXT_PUBLIC_ANALYTICS_ID=
